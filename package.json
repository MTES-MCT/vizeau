    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.1",
    "@aws-sdk/client-s3": "^3.994.0",
    "@aws-sdk/s3-request-presigner": "^3.994.0",
    "@codegouvfr/react-dsfr": "^1.28.0",
    "@duckdb/node-api": "^1.4.4-r.3",
    "@inertiajs/react": "^2.3.15",
    "@tailwindcss/vite": "^4.1.16",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.4.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "date-fns": "^4.1.0",
