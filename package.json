{
  "name": "vizeau",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "cd build && node bin/server.js",
    "build": "node ace build",
    "dev": "npx react-dsfr update-icons && node ace serve --hmr",
    "scalingo-postbuild": "./scalingo-postbuild.sh",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#types/*": "./types/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.1.0",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@japa/api-client": "^3.1.0",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^4.2.0",
    "@poppinss/file-generator": "^2.1.6",
    "@poppinss/ts-exec": "^1.4.4",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.18",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.3",
    "eslint-plugin-storybook": "^10.4.6",
    "hot-hook": "^0.4.0",
    "husky": "^9.1.7",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.56.1",
    "prettier": "^3.5.3",
    "storybook": "^10.4.6",
    "typescript": "~5.8.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/bouncer": "^4.0.0",
    "@adonisjs/core": "^7.3.4",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/drive": "^4.0.0",
    "@adonisjs/inertia": "^4.2.0",
