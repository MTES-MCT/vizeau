    "react-dom": "^19.2.7",
    "react-toastify": "^11.0.5",
    "reflect-metadata": "^0.2.2",
    "tailwindcss": "^4.1.16",
    "tinycolor2": "^1.6.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
